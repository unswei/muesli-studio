// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`live monitor snapshots > renders disconnected live monitor state with empty history 1`] = `"<main class="app-shell"><header class="topbar"><div class="brand-block"><p class="eyebrow">replay-first run inspection</p><h1>muesli-studio</h1><p class="topbar-copy muted">Understand a run quickly, trust what changed, and capture clean figures without fighting the interface.</p></div><div class="topbar-actions"><label class="file-input"><span>open replay</span><small>choose \`events.jsonl\`</small><input accept=".jsonl,application/json,text/plain" type="file"></label><label class="file-input"><span>open sidecar</span><small>optional tick index</small><input accept=".json,application/json" type="file"></label></div></header><section class="workspace-shell"><div class="workspace-main"><section class="panel instrument-panel empty-state-panel"><div class="panel-heading"><div><p class="panel-kicker">get started</p><h2>load a run</h2><p class="panel-copy muted">Open a recorded log or connect to a live runtime. Once events arrive, the tree becomes the dominant surface.</p></div></div><div class="empty-action-grid"><div class="empty-action"><h3>recorded replay</h3><p>Choose \`events.jsonl\`, then add the optional sidecar index for larger runs.</p></div><div class="empty-action"><h3>live monitor</h3><p>Connect a runtime over WebSocket and let new events append into the same inspection model.</p></div><div class="empty-action"><h3>clean capture</h3><p>Use the deterministic demo fixture as the baseline for screenshots, talks, and publication polish.</p></div></div></section><div class="panel tree-panel tree-panel--empty"><div class="empty-tree-state"><p class="panel-kicker">focal surface</p><h2>behaviour tree</h2><p class="panel-copy muted">Load a replay log to render a stable tree layout and inspect each tick without relayout noise.</p></div></div></div><aside class="workspace-sidebar"><section class="panel detail-panel live-panel"><div class="panel-heading"><div><p class="panel-kicker">live monitor</p><h2>connection</h2><p class="panel-copy muted">Follow the same canonical event stream over WebSocket.</p></div><span class="status-badge status-badge--disconnected">disconnected</span></div><div class="control-stack"><label class="live-url"><span>endpoint</span><input placeholder="ws://localhost:8765/events" type="url" value="ws://localhost:8765/events"></label><div class="button-row"><button type="button" class="button-primary">connect</button><button type="button" class="button-ghost" disabled="">disconnect</button><button type="button" class="button-ghost">clear history</button></div><div class="toggle-row"><label class="checkbox"><input type="checkbox" checked="">auto-follow</label><label class="checkbox"><input type="checkbox" checked="">auto-reconnect</label></div></div><p class="status-line muted">status <code>disconnected</code></p><div class="history-list compact"><p class="panel-empty-copy muted">No connection history yet.</p></div></section><section class="panel detail-panel"><div class="panel-heading"><div><p class="panel-kicker">side panels</p><h2>details</h2></div></div><p class="panel-copy muted">Node history, blackboard changes, and DSL editing appear here once a replay is loaded.</p><p class="panel-copy muted">Until then, use the loader above or connect to a live runtime from this sidebar.</p></section></aside></section></main>"`;

exports[`live monitor snapshots > renders error live monitor state with history entries and last event time 1`] = `"<main class="app-shell"><header class="topbar"><div class="brand-block"><p class="eyebrow">replay-first run inspection</p><h1>muesli-studio</h1><p class="topbar-copy muted">Understand a run quickly, trust what changed, and capture clean figures without fighting the interface.</p></div><div class="topbar-actions"><label class="file-input"><span>open replay</span><small>choose \`events.jsonl\`</small><input accept=".jsonl,application/json,text/plain" type="file"></label><label class="file-input"><span>open sidecar</span><small>optional tick index</small><input accept=".json,application/json" type="file"></label></div></header><section class="workspace-shell"><div class="workspace-main"><section class="panel instrument-panel empty-state-panel"><div class="panel-heading"><div><p class="panel-kicker">get started</p><h2>load a run</h2><p class="panel-copy muted">Open a recorded log or connect to a live runtime. Once events arrive, the tree becomes the dominant surface.</p></div></div><div class="empty-action-grid"><div class="empty-action"><h3>recorded replay</h3><p>Choose \`events.jsonl\`, then add the optional sidecar index for larger runs.</p></div><div class="empty-action"><h3>live monitor</h3><p>Connect a runtime over WebSocket and let new events append into the same inspection model.</p></div><div class="empty-action"><h3>clean capture</h3><p>Use the deterministic demo fixture as the baseline for screenshots, talks, and publication polish.</p></div></div></section><div class="panel tree-panel tree-panel--empty"><div class="empty-tree-state"><p class="panel-kicker">focal surface</p><h2>behaviour tree</h2><p class="panel-copy muted">Load a replay log to render a stable tree layout and inspect each tick without relayout noise.</p></div></div></div><aside class="workspace-sidebar"><section class="panel detail-panel live-panel"><div class="panel-heading"><div><p class="panel-kicker">live monitor</p><h2>connection</h2><p class="panel-copy muted">Follow the same canonical event stream over WebSocket.</p></div><span class="status-badge status-badge--error">error</span></div><div class="control-stack"><label class="live-url"><span>endpoint</span><input placeholder="ws://localhost:8765/events" type="url" value="ws://localhost:8765/events"></label><div class="button-row"><button type="button" class="button-primary">connect</button><button type="button" class="button-ghost">disconnect</button><button type="button" class="button-ghost">clear history</button></div><div class="toggle-row"><label class="checkbox"><input type="checkbox" checked="">auto-follow</label><label class="checkbox"><input type="checkbox" checked="">auto-reconnect</label></div></div><p class="status-line muted">status <code>error</code> · connection closed: 1006 · last event t1710000000000</p><div class="history-list compact"><ul class="detail-list"><li class="detail-list-item"><div class="detail-list-row"><span class="detail-list-primary">[t1700000000500]</span><span class="status-badge status-badge--history-error">error</span></div><span class="detail-list-secondary">WebSocket error</span></li><li class="detail-list-item"><div class="detail-list-row"><span class="detail-list-primary">[t1700000000000]</span><span class="status-badge status-badge--history-warning">warning</span></div><span class="detail-list-secondary">Retry 1 in 500ms</span></li></ul></div></section><section class="panel detail-panel"><div class="panel-heading"><div><p class="panel-kicker">side panels</p><h2>details</h2></div></div><p class="panel-copy muted">Node history, blackboard changes, and DSL editing appear here once a replay is loaded.</p><p class="panel-copy muted">Until then, use the loader above or connect to a live runtime from this sidebar.</p></section></aside></section></main>"`;
