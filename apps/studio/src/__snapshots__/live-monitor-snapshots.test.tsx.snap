// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`live monitor snapshots > renders disconnected live monitor state with empty history 1`] = `"<main class="app-shell"><header class="header"><div><h1>muesli-studio</h1><p class="muted">Replay + live monitoring over WebSocket, sharing one append-only replay engine.</p></div><div class="live-controls"><label class="file-input"><span>open JSONL</span><input accept=".jsonl,application/json,text/plain" type="file"></label><label class="file-input"><span>open sidecar (optional)</span><input accept=".json,application/json" type="file"></label></div></header><section class="panel controls"><h2>live monitor</h2><div class="live-controls"><label class="live-url"><span>endpoint</span><input placeholder="ws://localhost:8765/events" type="url" value="ws://localhost:8765/events"></label><button type="button">connect</button><button type="button" disabled="">disconnect</button><label class="checkbox"><input type="checkbox" checked="">auto-follow</label><label class="checkbox"><input type="checkbox" checked="">auto-reconnect</label><button type="button">clear history</button></div><p class="muted">status: <code>disconnected</code></p><div class="history-list compact"><p class="muted">No connection history yet.</p></div></section><section class="content-grid"><div class="panel empty">Load a replay log to begin.</div></section></main>"`;

exports[`live monitor snapshots > renders error live monitor state with history entries and last event time 1`] = `"<main class="app-shell"><header class="header"><div><h1>muesli-studio</h1><p class="muted">Replay + live monitoring over WebSocket, sharing one append-only replay engine.</p></div><div class="live-controls"><label class="file-input"><span>open JSONL</span><input accept=".jsonl,application/json,text/plain" type="file"></label><label class="file-input"><span>open sidecar (optional)</span><input accept=".json,application/json" type="file"></label></div></header><section class="panel controls"><h2>live monitor</h2><div class="live-controls"><label class="live-url"><span>endpoint</span><input placeholder="ws://localhost:8765/events" type="url" value="ws://localhost:8765/events"></label><button type="button">connect</button><button type="button">disconnect</button><label class="checkbox"><input type="checkbox" checked="">auto-follow</label><label class="checkbox"><input type="checkbox" checked="">auto-reconnect</label><button type="button">clear history</button></div><p class="muted">status: <code>error</code> - connection closed: 1006 · last event t1710000000000</p><div class="history-list compact"><ul><li>[t1700000000500] error: WebSocket error</li><li>[t1700000000000] warning: Retry 1 in 500ms</li></ul></div></section><section class="content-grid"><div class="panel empty">Load a replay log to begin.</div></section></main>"`;
